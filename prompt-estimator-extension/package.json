{
  "name": "prompt-cost-estimator",
  "displayName": "Prompt Cost Estimator",
  "description": "Predictive token and AI Credit (AIC) estimator for selected text.",
  "version": "1.3.0",
  "publisher": "AkashAi7",
  "repository": {
    "type": "git",
    "url": "https://github.com/AkashAi7/ai-credit-calculator"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "prompt-cost-estimator.estimate",
        "name": "estimate",
        "description": "Estimate tokens and AI cost of a prompt and its attached context",
        "isSticky": false
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prompt-estimator-container",
          "title": "Prompt Cost Sandbox",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "prompt-estimator-container": [
        {
          "id": "prompt-estimator.sidebar",
          "name": "AI Prompt Sandbox",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "prompt-cost-estimator.estimate",
        "title": "Estimate Prompt Cost"
      }
    ],
    "configuration": {
      "title": "Prompt Cost Estimator",
      "properties": {
        "promptCostEstimator.model": {
          "type": "string",
          "enum": [
            "Claude Haiku 4.5",
            "Gemini 3 Flash",
            "GPT-5.4 mini",
            "GPT-4o"
          ],
          "default": "Claude Haiku 4.5",
          "description": "Select the model to estimate pricing for."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.1.3",
    "@vscode/vsce": "^2.19.0"
  }
}
